{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "moduleDetection": "force",
    "module": "preserve",
    "moduleResolution": "Bundler",
    "paths": {
      "@quini/core": [
        "./packages/core/src/"
      ]
    },
    "types": [
      "node"
    ],
    "strict": true,
    "declaration": true,
    "noEmit": true,
    "sourceMap": true,
    "esModuleInterop": false,
    "isolatedModules": true,
    "skipLibCheck": true
  }
}
